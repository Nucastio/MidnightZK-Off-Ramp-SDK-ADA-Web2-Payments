CARDANO_BACKEND=blockfrost
CARDANO_NETWORK=Preprod
BLOCKFROST_URL=https://cardano-preprod.blockfrost.io/api/v0
BLOCKFROST_PROJECT_ID=your_preprod_blockfrost_project_id
BLOCKFROST_API_KEY=your_preprod_blockfrost_project_id

WALLET_MNEMONIC="your 24-word preprod mnemonic"
SENDER_WALLET_MNEMONIC="your 24-word preprod mnemonic"
OPERATOR_WALLET_MNEMONIC="your 24-word preprod mnemonic"

MIDNIGHT_DEPLOY_NETWORK=undeployed
BIP39_MNEMONIC="your 24-word midnight mnemonic"
# Optional endpoint overrides; defaults are selected from MIDNIGHT_DEPLOY_NETWORK.
MIDNIGHT_INDEXER_HTTP=
MIDNIGHT_INDEXER_WS=
MIDNIGHT_NODE_RPC=
MIDNIGHT_PROOF_SERVER=
MIDNIGHT_OFFRAMP_ARTIFACTS_DIR=
MIDNIGHT_PRIVATE_STATE_STORE=offramp-local-private-state
MIDNIGHT_LDB_PASSWORD=replace_with_at_least_16_characters
MIDNIGHT_WALLET_SYNC_MS=180000
MIDNIGHT_VERIFY_TX_MS=60000
MIDNIGHT_BALANCE_TX_MS=900000

OPERATOR_ED25519_SK_HEX=replace_with_32_byte_hex

API_PORT=8788
UI_PORT=5174
OFFRAMP_DATA_DIR=data
ESCROW_DEADLINE_SECONDS=900
ESCROW_LOCK_LOVELACE=2000000

RAIL_ADAPTER_MODE=mock

# Shared HMAC key for rail-adapter webhook verification. REQUIRED — the oracle
# fails closed (no dev default) when unset.
RAIL_WEBHOOK_HMAC_KEY=replace_with_shared_webhook_hmac_key

# Backend security (backend/api).
# Comma-separated CORS allowlist; empty ⇒ no cross-origin browser access.
OFFRAMP_ALLOWED_ORIGINS=http://127.0.0.1:5174,http://localhost:5174
# Test endpoints (/api/test/run-suite, /api/testing-report) are 403 unless "1".
OFFRAMP_ENABLE_TEST_ENDPOINTS=0
# Optional shared secret required via X-Test-Token when test endpoints are on.
OFFRAMP_TEST_TOKEN=
# Release authorization validity window in ms (default 600000).
OFFRAMP_RELEASE_AUTH_WINDOW_MS=600000
